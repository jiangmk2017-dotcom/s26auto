name: Auto Run S26 Strategy

# 定时规则：每2小时执行一次，可自行修改
on:
  schedule:
    - cron: '0 */2 * * *'
  # 允许手动点击触发
  workflow_dispatch:

jobs:
  run-strategy:
    runs-on: ubuntu-latest
    env:
      # 注入 GitHub 私密变量
      GOOGLE_CREDENTIALS_JSON: ${{ secrets.GOOGLE_CREDENTIALS_JSON }}
      GOOGLE_TOKEN_JSON: ${{ secrets.GOOGLE_TOKEN_JSON }}
    steps:
      - name: 拉取仓库代码
        uses: actions/checkout@v4

      - name: 设置 Python3 环境
        uses: actions/setup-python@v5
        with:
          python-version: "3.10"

      - name: 还原 Google token.json 文件
        run: echo "${{ secrets.GOOGLE_TOKEN_JSON }}" > token.json

      - name: 安装依赖库
        run: |
          python -m pip install --upgrade pip
          pip install gspread requests pandas numpy talib

      - name: 运行 S26 策略
        run: python s26.py
